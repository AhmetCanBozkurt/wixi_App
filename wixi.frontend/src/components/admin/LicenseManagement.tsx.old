import React, { useState, useEffect, useCallback, useMemo } from 'react';
import { FaKey, FaEdit, FaTrash, FaPlus, FaLink, FaCheckCircle, FaTimesCircle } from 'react-icons/fa';
import licenseService from '../../ApiServices/services/LicenseService';
import tenantService from '../../ApiServices/services/TenantService';
import { useToast } from '../../hooks/use-toast';
import { AlertDialog, AlertDialogAction, AlertDialogCancel, AlertDialogContent, AlertDialogDescription, AlertDialogFooter, AlertDialogHeader, AlertDialogTitle } from '../ui/alert-dialog';
import { Button } from '../ui/button';
import { Input } from '../ui/input';
import { Label } from '../ui/label';
import { Dialog, DialogContent, DialogDescription, DialogFooter, DialogHeader, DialogTitle } from '../ui/dialog';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '../ui/select';
import { Textarea } from '../ui/textarea';
import { DataTable, type ColumnDef, type TablePreferenceState } from '../ui/DataTable';
import { tablePreferenceService } from '../../ApiServices/services';
import type { LicenseDto, CreateLicenseDto, AssignLicenseDto, TenantDto } from '../../ApiServices/types/LicensingTypes';
import type { TablePreferenceDto } from '../../ApiServices/types/TablePreferenceTypes';
import { format } from 'date-fns';

const LICENSE_TABLE_KEY = 'admin-licenses';

type LicenseWithId = LicenseDto & { id: number };

const LicenseManagement: React.FC = () => {
  const [licenses, setLicenses] = useState<LicenseWithId[]>([]);
  const [tenants, setTenants] = useState<TenantDto[]>([]);
  const [loading, setLoading] = useState(true);
  const [showCreate, setShowCreate] = useState(false);
  const [showAssign, setShowAssign] = useState(false);
  const [editingLicense, setEditingLicense] = useState<LicenseDto | null>(null);
  const [deletingLicense, setDeletingLicense] = useState<LicenseDto | null>(null);
  const [assigningLicense, setAssigningLicense] = useState<LicenseDto | null>(null);
  const [form, setForm] = useState<CreateLicenseDto>({
    licenseKey: '',
    tenantId: undefined,
    expireDate: '',
    isActive: true,
    planName: '',
    maxUser: undefined,
    allowedModules: [],
    machineBindingMode: '',
    notes: '',
  });
  const [assignForm, setAssignForm] = useState<AssignLicenseDto>({ licenseId: 0, tenantId: 0 });
  const [moduleInput, setModuleInput] = useState('');
  const [preferences, setPreferences] = useState<TablePreferenceDto | null>(null);
  const [prefLoaded, setPrefLoaded] = useState(false);
  const { toast } = useToast();

  useEffect(() => {
    loadLicenses();
    loadTenants();
    loadPreferences();
  }, []);

  const loadPreferences = async () => {
    try {
      const pref = await tablePreferenceService.getTablePreference(LICENSE_TABLE_KEY);
      setPreferences(pref);
    } catch (error) {
      console.error('Table preferences could not be loaded:', error);
    } finally {
      setPrefLoaded(true);
    }
  };

  const loadLicenses = async () => {
    try {
      setLoading(true);
      const result = await licenseService.getAllLicenses();
      if (result.success && result.data) {
        // Map licenseId to id for DataTable compatibility
        const mappedLicenses = result.data.map(license => ({ ...license, id: license.licenseId })) as LicenseWithId[];
        setLicenses(mappedLicenses);
      } else {
        toast({
          variant: 'destructive',
          title: 'Hata',
          description: result.error || 'Lisanslar yüklenemedi',
        });
      }
    } catch (error) {
      toast({
        variant: 'destructive',
        title: 'Hata',
        description: 'Lisanslar yüklenirken bir hata oluştu',
      });
    } finally {
      setLoading(false);
    }
  };

  const loadTenants = async () => {
    try {
      const result = await tenantService.getAllTenants();
      if (result.success && result.data) {
        setTenants(result.data);
      }
    } catch (error) {
      console.error('Error loading tenants:', error);
    }
  };

  const handleCreate = async () => {
    try {
      const createDto: CreateLicenseDto = {
        ...form,
        allowedModules: form.allowedModules && form.allowedModules.length > 0 ? form.allowedModules : undefined,
        maxUser: form.maxUser || undefined,
        tenantId: form.tenantId || undefined,
      };
      const result = await licenseService.createLicense(createDto);
      if (result.success && result.data) {
        toast({
          title: 'Başarılı',
          description: 'Lisans başarıyla oluşturuldu',
        });
        setShowCreate(false);
        resetForm();
        loadLicenses();
      } else {
        toast({
          variant: 'destructive',
          title: 'Hata',
          description: result.error || 'Lisans oluşturulamadı',
        });
      }
    } catch (error) {
      toast({
        variant: 'destructive',
        title: 'Hata',
        description: 'Lisans oluşturulurken bir hata oluştu',
      });
    }
  };

  const handleUpdate = async () => {
    if (!editingLicense) return;
    try {
      const updateDto: CreateLicenseDto = {
        ...form,
        allowedModules: form.allowedModules && form.allowedModules.length > 0 ? form.allowedModules : undefined,
        maxUser: form.maxUser || undefined,
        tenantId: form.tenantId || undefined,
      };
      const result = await licenseService.updateLicense(editingLicense.licenseId, updateDto);
      if (result.success && result.data) {
        toast({
          title: 'Başarılı',
          description: 'Lisans başarıyla güncellendi',
        });
        setEditingLicense(null);
        resetForm();
        loadLicenses();
      } else {
        toast({
          variant: 'destructive',
          title: 'Hata',
          description: result.error || 'Lisans güncellenemedi',
        });
      }
    } catch (error) {
      toast({
        variant: 'destructive',
        title: 'Hata',
        description: 'Lisans güncellenirken bir hata oluştu',
      });
    }
  };

  const handleAssign = async () => {
    try {
      const result = await licenseService.assignLicenseToTenant(assignForm);
      if (result.success && result.data) {
        toast({
          title: 'Başarılı',
          description: 'Lisans başarıyla müşteriye atandı',
        });
        setShowAssign(false);
        setAssigningLicense(null);
        setAssignForm({ licenseId: 0, tenantId: 0 });
        loadLicenses();
      } else {
        toast({
          variant: 'destructive',
          title: 'Hata',
          description: result.error || 'Lisans atanamadı',
        });
      }
    } catch (error) {
      toast({
        variant: 'destructive',
        title: 'Hata',
        description: 'Lisans atanırken bir hata oluştu',
      });
    }
  };

  const handleDelete = async () => {
    if (!deletingLicense) return;
    try {
      const result = await licenseService.deleteLicense(deletingLicense.licenseId);
      if (result.success) {
        toast({
          title: 'Başarılı',
          description: 'Lisans başarıyla silindi',
        });
        setDeletingLicense(null);
        loadLicenses();
      } else {
        toast({
          variant: 'destructive',
          title: 'Hata',
          description: result.error || 'Lisans silinemedi',
        });
      }
    } catch (error) {
      toast({
        variant: 'destructive',
        title: 'Hata',
        description: 'Lisans silinirken bir hata oluştu',
      });
    }
  };

  const generateLicenseKey = (): string => {
    // Generate a license key in format: XXXX-XXXX-XXXX-XXXX
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789'; // Excluding confusing characters like 0, O, I, 1
    const segments = [4, 4, 4, 4];
    return segments.map(segmentLength => {
      return Array.from({ length: segmentLength }, () => 
        chars.charAt(Math.floor(Math.random() * chars.length))
      ).join('');
    }).join('-');
  };

  const resetForm = () => {
    setForm({
      licenseKey: generateLicenseKey(),
      tenantId: undefined,
      expireDate: '',
      isActive: true,
      planName: '',
      maxUser: undefined,
      allowedModules: [],
      machineBindingMode: '',
      notes: '',
    });
    setModuleInput('');
  };

  const openEditDialog = (license: LicenseWithId) => {
    setEditingLicense(license);
    setForm({
      licenseKey: license.licenseKey || '', // Show the actual license key
      tenantId: license.tenantId,
      expireDate: license.expireDate ? license.expireDate.split('T')[0] : '',
      isActive: license.isActive,
      planName: license.planName || '',
      maxUser: license.maxUser,
      allowedModules: license.allowedModules || [],
      machineBindingMode: license.machineBindingMode || '',
      notes: license.notes || '',
    });
    setModuleInput((license.allowedModules || []).join(', '));
  };

  const openAssignDialog = (license: LicenseDto) => {
    setAssigningLicense(license);
    setAssignForm({ licenseId: license.licenseId, tenantId: license.tenantId || 0 });
    setShowAssign(true);
  };

  const addModule = () => {
    if (moduleInput.trim()) {
      const modules = moduleInput.split(',').map(m => m.trim()).filter(m => m);
      setForm({ ...form, allowedModules: [...(form.allowedModules || []), ...modules] });
      setModuleInput('');
    }
  };

  const removeModule = (module: string) => {
    setForm({
      ...form,
      allowedModules: (form.allowedModules || []).filter(m => m !== module),
    });
  };

  const initialPreferences = useMemo<TablePreferenceState | undefined>(() => {
    if (!preferences) return undefined;
    return {
      tableKey: LICENSE_TABLE_KEY,
      visibleColumns: preferences.visibleColumns ?? [],
      columnOrder: preferences.columnOrder ?? [],
      columnFilters: preferences.columnFilters ?? {},
      sortConfig: {
        key: preferences.sortConfig?.key ?? '',
        direction: (preferences.sortConfig?.direction as 'asc' | 'desc' | null) ?? null,
      },
      pageSize: preferences.pageSize ?? 20,
    };
  }, [preferences]);

  const handlePreferenceChange = useCallback(async (state: TablePreferenceState) => {
    if (!prefLoaded) return;
    try {
      await tablePreferenceService.saveTablePreference(LICENSE_TABLE_KEY, {
        tableKey: LICENSE_TABLE_KEY,
        visibleColumns: state.visibleColumns,
        columnOrder: state.columnOrder,
        columnFilters: state.columnFilters,
        sortConfig: state.sortConfig,
        pageSize: state.pageSize,
      });
    } catch (error) {
      console.error('Table preferences could not be saved:', error);
    }
  }, [prefLoaded]);

  const handleExport = useCallback(async (rows: LicenseWithId[]) => {
    try {
      const XLSX = await import('xlsx');
      const workbook = XLSX.utils.book_new();

      const exportData = rows.map((row) => ({
        'ID': row.licenseId,
        'Lisans Anahtarı': row.licenseKey || '-',
        'Müşteri': row.tenantCompanyName || '-',
        'Plan': row.planName || '-',
        'Durum': row.isActive ? 'Aktif' : 'Pasif',
        'Geçerlilik': row.isValid ? 'Geçerli' : 'Geçersiz',
        'Bitiş Tarihi': row.expireDate ? format(new Date(row.expireDate), 'dd.MM.yyyy HH:mm') : 'Sınırsız',
        'Max Kullanıcı': row.maxUser || 'Sınırsız',
        'Modüller': (row.allowedModules || []).join(', ') || '-',
        'Oluşturulma': format(new Date(row.createDate), 'dd.MM.yyyy HH:mm'),
      }));

      const worksheet = XLSX.utils.json_to_sheet(exportData);
      XLSX.utils.book_append_sheet(workbook, worksheet, 'Lisanslar');
      const dateStr = format(new Date(), 'yyyy-MM-dd');
      XLSX.writeFile(workbook, `lisanslar_${dateStr}.xlsx`);

      toast({
        title: 'Başarılı',
        description: `${rows.length} kayıt Excel olarak indirildi.`,
      });
    } catch (error) {
      console.error('Export error:', error);
      toast({
        variant: 'destructive',
        title: 'Hata',
        description: 'Excel dosyası oluşturulamadı.',
      });
    }
  }, [toast]);

  const columns: ColumnDef<LicenseWithId>[] = useMemo(
    () => [
      {
        id: 'licenseId',
        header: 'ID',
        accessorKey: 'licenseId',
        width: '80px',
        filterType: 'text',
        cell: (value) => <span className="text-sm text-gray-600">{value as number}</span>,
      },
      {
        id: 'licenseKey',
        header: 'Lisans Anahtarı',
        accessorKey: 'licenseKey',
        width: '250px',
        filterType: 'text',
        cell: (value) => (
          <span className="text-sm font-mono text-gray-800 bg-gray-50 px-2 py-1 rounded">
            {value || '-'}
          </span>
        ),
      },
      {
        id: 'tenantCompanyName',
        header: 'Müşteri',
        accessorKey: 'tenantCompanyName',
        width: '200px',
        filterType: 'text',
        cell: (value) => <span className="text-sm">{value || '-'}</span>,
      },
      {
        id: 'planName',
        header: 'Plan',
        accessorKey: 'planName',
        width: '120px',
        filterType: 'list',
        cell: (value) => <span className="text-sm">{value || '-'}</span>,
      },
      {
        id: 'isActive',
        header: 'Durum',
        accessorKey: 'isActive',
        width: '100px',
        filterType: 'list',
        cell: (value) => {
          const isActive = value as boolean;
          return (
            <span className={`px-2 py-1 text-xs rounded-full ${
              isActive 
                ? 'bg-green-100 text-green-800' 
                : 'bg-red-100 text-red-800'
            }`}>
              {isActive ? 'Aktif' : 'Pasif'}
            </span>
          );
        },
      },
      {
        id: 'isValid',
        header: 'Geçerlilik',
        accessorKey: 'isValid',
        width: '100px',
        filterType: 'list',
        cell: (value, row) => {
          const isValid = row.isValid;
          return isValid ? (
            <FaCheckCircle className="text-green-600" />
          ) : (
            <FaTimesCircle className="text-red-600" />
          );
        },
      },
      {
        id: 'expireDate',
        header: 'Bitiş Tarihi',
        accessorKey: 'expireDate',
        width: '150px',
        filterType: 'text',
        cell: (value) => (
          <span className="text-sm text-gray-600">
            {value ? format(new Date(value as string), 'dd.MM.yyyy') : 'Sınırsız'}
          </span>
        ),
      },
      {
        id: 'maxUser',
        header: 'Max Kullanıcı',
        accessorKey: 'maxUser',
        width: '120px',
        filterType: 'text',
        cell: (value) => <span className="text-sm text-gray-600">{value || 'Sınırsız'}</span>,
      },
      {
        id: 'allowedModules',
        header: 'Modüller',
        accessorKey: 'allowedModules',
        width: '200px',
        filterType: 'text',
        cell: (value) => {
          const modules = value as string[] | undefined;
          return (
            <span className="text-sm text-gray-600">
              {modules && modules.length > 0 ? modules.join(', ') : '-'}
            </span>
          );
        },
      },
      {
        id: 'createDate',
        header: 'Oluşturulma',
        accessorKey: 'createDate',
        width: '180px',
        filterType: 'text',
        cell: (value) => (
          <span className="text-sm text-gray-500">
            {format(new Date(value as string), 'dd.MM.yyyy HH:mm')}
          </span>
        ),
      },
    ],
    []
  );

  if (!prefLoaded) {
    return (
      <div className="flex items-center justify-center h-64">
        <div className="text-lg">Yükleniyor...</div>
      </div>
    );
  }

  return (
    <div className="p-6">
      <div className="flex justify-between items-center mb-6">
        <h1 className="text-2xl font-bold flex items-center gap-2">
          <FaKey className="text-blue-600" />
          Lisans Yönetimi
        </h1>
        <Button onClick={() => setShowCreate(true)} className="flex items-center gap-2">
          <FaPlus /> Yeni Lisans
        </Button>
      </div>

      <DataTable
        data={licenses}
        columns={columns}
        onEdit={openEditDialog}
        onDelete={(licenses) => setDeletingLicense(licenses[0])}
        onExport={handleExport}
        searchPlaceholder="Lisans ara..."
        pageSize={20}
        tableKey={LICENSE_TABLE_KEY}
        initialPreferences={initialPreferences}
        onPreferencesChange={handlePreferenceChange}
        loading={loading}
      />

      {/* Custom Actions - Assign Button */}
      <div className="mt-4">
        {licenses.map((license) => (
          <div key={license.licenseId} className="hidden">
            <Button
              variant="outline"
              size="sm"
              onClick={() => openAssignDialog(license)}
              className="flex items-center gap-1"
            >
              <FaLink /> Ata
            </Button>
          </div>
        ))}
      </div>

      {/* Create Dialog */}
      <Dialog open={showCreate} onOpenChange={(open) => {
        setShowCreate(open);
        if (open) {
          resetForm(); // Generate new license key when modal opens
        }
      }}>
        <DialogContent className="max-w-2xl max-h-[90vh] overflow-y-auto">
          <DialogHeader>
            <DialogTitle>Yeni Lisans Oluştur</DialogTitle>
            <DialogDescription>Yeni bir lisans oluşturun</DialogDescription>
          </DialogHeader>
          <div className="space-y-4">
            <div>
              <Label htmlFor="licenseKey">Lisans Anahtarı *</Label>
              <div className="flex gap-2">
                <Input
                  id="licenseKey"
                  value={form.licenseKey}
                  onChange={(e) => setForm({ ...form, licenseKey: e.target.value })}
                  placeholder="XXXX-XXXX-XXXX-XXXX"
                />
                <Button
                  type="button"
                  variant="outline"
                  onClick={() => setForm({ ...form, licenseKey: generateLicenseKey() })}
                  title="Yeni anahtar oluştur"
                >
                  🔄
                </Button>
              </div>
            </div>
            <div>
              <Label htmlFor="tenantId">Müşteri</Label>
              <Select
                value={form.tenantId?.toString() || 'none'}
                onValueChange={(value) => setForm({ ...form, tenantId: value === 'none' ? undefined : parseInt(value) })}
              >
                <SelectTrigger>
                  <SelectValue placeholder="Müşteri seçin (opsiyonel)" />
                </SelectTrigger>
                <SelectContent>
                  <SelectItem value="none">Müşteri seçilmedi</SelectItem>
                  {tenants.map((tenant) => (
                    <SelectItem key={tenant.tenantId} value={tenant.tenantId.toString()}>
                      {tenant.companyName}
                    </SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>
            <div>
              <Label htmlFor="expireDate">Bitiş Tarihi</Label>
              <Input
                id="expireDate"
                type="date"
                value={form.expireDate}
                onChange={(e) => setForm({ ...form, expireDate: e.target.value })}
              />
            </div>
            <div className="flex gap-4">
              <div className="flex-1">
                <Label htmlFor="planName">Plan</Label>
                <Select value={form.planName} onValueChange={(value) => setForm({ ...form, planName: value })}>
                  <SelectTrigger>
                    <SelectValue placeholder="Plan seçin" />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="Basic">Basic</SelectItem>
                    <SelectItem value="Pro">Pro</SelectItem>
                    <SelectItem value="Enterprise">Enterprise</SelectItem>
                  </SelectContent>
                </Select>
              </div>
              <div className="flex-1">
                <Label htmlFor="maxUser">Max Kullanıcı</Label>
                <Input
                  id="maxUser"
                  type="number"
                  value={form.maxUser || ''}
                  onChange={(e) => setForm({ ...form, maxUser: e.target.value ? parseInt(e.target.value) : undefined })}
                  placeholder="Sınırsız"
                />
              </div>
            </div>
            <div>
              <Label htmlFor="machineBindingMode">Makine Bağlama Modu</Label>
              <Select
                value={form.machineBindingMode}
                onValueChange={(value) => setForm({ ...form, machineBindingMode: value })}
              >
                <SelectTrigger>
                  <SelectValue placeholder="Mod seçin" />
                </SelectTrigger>
                <SelectContent>
                  <SelectItem value="SinglePC">Tek PC</SelectItem>
                  <SelectItem value="MultiPC">Çoklu PC</SelectItem>
                </SelectContent>
              </Select>
            </div>
            <div>
              <Label htmlFor="modules">Modüller (virgülle ayırın)</Label>
              <div className="flex gap-2">
                <Input
                  id="modules"
                  value={moduleInput}
                  onChange={(e) => setModuleInput(e.target.value)}
                  placeholder="Projects, Appointments, Documents"
                  onKeyPress={(e) => e.key === 'Enter' && addModule()}
                />
                <Button type="button" onClick={addModule}>Ekle</Button>
              </div>
              {form.allowedModules && form.allowedModules.length > 0 && (
                <div className="flex flex-wrap gap-2 mt-2">
                  {form.allowedModules.map((module, index) => (
                    <span
                      key={index}
                      className="px-2 py-1 bg-blue-100 text-blue-800 rounded text-sm flex items-center gap-1"
                    >
                      {module}
                      <button
                        type="button"
                        onClick={() => removeModule(module)}
                        className="text-blue-600 hover:text-blue-800"
                      >
                        ×
                      </button>
                    </span>
                  ))}
                </div>
              )}
            </div>
            <div>
              <Label htmlFor="notes">Notlar</Label>
              <Textarea
                id="notes"
                value={form.notes}
                onChange={(e) => setForm({ ...form, notes: e.target.value })}
                placeholder="Lisans hakkında notlar..."
                rows={3}
              />
            </div>
            <div className="flex items-center gap-2">
              <input
                type="checkbox"
                id="isActive"
                checked={form.isActive}
                onChange={(e) => setForm({ ...form, isActive: e.target.checked })}
                className="rounded"
              />
              <Label htmlFor="isActive">Aktif</Label>
            </div>
          </div>
          <DialogFooter>
            <Button variant="outline" onClick={() => setShowCreate(false)}>İptal</Button>
            <Button onClick={handleCreate}>Oluştur</Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* Edit Dialog */}
      <Dialog open={!!editingLicense} onOpenChange={() => { setEditingLicense(null); resetForm(); }}>
        <DialogContent className="max-w-2xl max-h-[90vh] overflow-y-auto">
          <DialogHeader>
            <DialogTitle>Lisans Düzenle</DialogTitle>
            <DialogDescription>Lisans bilgilerini güncelleyin</DialogDescription>
          </DialogHeader>
          <div className="space-y-4">
            <div>
              <Label>Lisans Anahtarı</Label>
              <Input 
                value={editingLicense?.licenseKey || ''} 
                disabled 
                className="font-mono bg-gray-50"
              />
              <p className="text-xs text-gray-500 mt-1">Lisans anahtarı değiştirilemez</p>
            </div>
            <div>
              <Label htmlFor="edit-tenantId">Müşteri</Label>
              <Select
                value={form.tenantId?.toString() || 'none'}
                onValueChange={(value) => setForm({ ...form, tenantId: value === 'none' ? undefined : parseInt(value) })}
              >
                <SelectTrigger>
                  <SelectValue placeholder="Müşteri seçin" />
                </SelectTrigger>
                <SelectContent>
                  <SelectItem value="none">Müşteri seçilmedi</SelectItem>
                  {tenants.map((tenant) => (
                    <SelectItem key={tenant.tenantId} value={tenant.tenantId.toString()}>
                      {tenant.companyName}
                    </SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>
            <div>
              <Label htmlFor="edit-expireDate">Bitiş Tarihi</Label>
              <Input
                id="edit-expireDate"
                type="date"
                value={form.expireDate}
                onChange={(e) => setForm({ ...form, expireDate: e.target.value })}
              />
            </div>
            <div className="flex gap-4">
              <div className="flex-1">
                <Label htmlFor="edit-planName">Plan</Label>
                <Select value={form.planName} onValueChange={(value) => setForm({ ...form, planName: value })}>
                  <SelectTrigger>
                    <SelectValue placeholder="Plan seçin" />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="Basic">Basic</SelectItem>
                    <SelectItem value="Pro">Pro</SelectItem>
                    <SelectItem value="Enterprise">Enterprise</SelectItem>
                  </SelectContent>
                </Select>
              </div>
              <div className="flex-1">
                <Label htmlFor="edit-maxUser">Max Kullanıcı</Label>
                <Input
                  id="edit-maxUser"
                  type="number"
                  value={form.maxUser || ''}
                  onChange={(e) => setForm({ ...form, maxUser: e.target.value ? parseInt(e.target.value) : undefined })}
                  placeholder="Sınırsız"
                />
              </div>
            </div>
            <div>
              <Label htmlFor="edit-machineBindingMode">Makine Bağlama Modu</Label>
              <Select
                value={form.machineBindingMode}
                onValueChange={(value) => setForm({ ...form, machineBindingMode: value })}
              >
                <SelectTrigger>
                  <SelectValue placeholder="Mod seçin" />
                </SelectTrigger>
                <SelectContent>
                  <SelectItem value="SinglePC">Tek PC</SelectItem>
                  <SelectItem value="MultiPC">Çoklu PC</SelectItem>
                </SelectContent>
              </Select>
            </div>
            <div>
              <Label htmlFor="edit-modules">Modüller</Label>
              <div className="flex gap-2">
                <Input
                  id="edit-modules"
                  value={moduleInput}
                  onChange={(e) => setModuleInput(e.target.value)}
                  placeholder="Projects, Appointments"
                  onKeyPress={(e) => e.key === 'Enter' && addModule()}
                />
                <Button type="button" onClick={addModule}>Ekle</Button>
              </div>
              {form.allowedModules && form.allowedModules.length > 0 && (
                <div className="flex flex-wrap gap-2 mt-2">
                  {form.allowedModules.map((module, index) => (
                    <span
                      key={index}
                      className="px-2 py-1 bg-blue-100 text-blue-800 rounded text-sm flex items-center gap-1"
                    >
                      {module}
                      <button
                        type="button"
                        onClick={() => removeModule(module)}
                        className="text-blue-600 hover:text-blue-800"
                      >
                        ×
                      </button>
                    </span>
                  ))}
                </div>
              )}
            </div>
            <div>
              <Label htmlFor="edit-notes">Notlar</Label>
              <Textarea
                id="edit-notes"
                value={form.notes}
                onChange={(e) => setForm({ ...form, notes: e.target.value })}
                rows={3}
              />
            </div>
            <div className="flex items-center gap-2">
              <input
                type="checkbox"
                id="edit-isActive"
                checked={form.isActive}
                onChange={(e) => setForm({ ...form, isActive: e.target.checked })}
                className="rounded"
              />
              <Label htmlFor="edit-isActive">Aktif</Label>
            </div>
          </div>
          <DialogFooter>
            <Button variant="outline" onClick={() => { setEditingLicense(null); resetForm(); }}>İptal</Button>
            <Button onClick={handleUpdate}>Güncelle</Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* Assign Dialog */}
      <Dialog open={showAssign} onOpenChange={setShowAssign}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Lisansı Müşteriye Ata</DialogTitle>
            <DialogDescription>
              {assigningLicense && `Lisans #${assigningLicense.licenseId} için müşteri seçin`}
            </DialogDescription>
          </DialogHeader>
          <div className="space-y-4">
            <div>
              <Label htmlFor="assign-tenantId">Müşteri *</Label>
              <Select
                value={assignForm.tenantId.toString()}
                onValueChange={(value) => setAssignForm({ ...assignForm, tenantId: parseInt(value) })}
              >
                <SelectTrigger>
                  <SelectValue placeholder="Müşteri seçin" />
                </SelectTrigger>
                <SelectContent>
                  {tenants.map((tenant) => (
                    <SelectItem key={tenant.tenantId} value={tenant.tenantId.toString()}>
                      {tenant.companyName}
                    </SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>
          </div>
          <DialogFooter>
            <Button variant="outline" onClick={() => { setShowAssign(false); setAssigningLicense(null); }}>İptal</Button>
            <Button onClick={handleAssign}>Ata</Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* Delete Confirmation */}
      <AlertDialog open={!!deletingLicense} onOpenChange={(open) => !open && setDeletingLicense(null)}>
        <AlertDialogContent>
          <AlertDialogHeader>
            <AlertDialogTitle>Lisansı Sil</AlertDialogTitle>
            <AlertDialogDescription>
              Lisans #{deletingLicense?.licenseId} silmek istediğinizden emin misiniz? Bu işlem geri alınamaz.
            </AlertDialogDescription>
          </AlertDialogHeader>
          <AlertDialogFooter>
            <AlertDialogCancel>İptal</AlertDialogCancel>
            <AlertDialogAction onClick={handleDelete} className="bg-red-600 hover:bg-red-700">
              Sil
            </AlertDialogAction>
          </AlertDialogFooter>
        </AlertDialogContent>
      </AlertDialog>
    </div>
  );
};

export default LicenseManagement;
