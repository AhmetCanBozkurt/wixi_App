# ─── Lokal Dev (docker-compose.yml) ─────────────────────────────────────────
DB_SA_PASSWORD=YourStrong!Password123
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# ─── Staging (GitHub Secret olarak da eklenir) ───────────────────────────────
STAGING_DB_CONNECTION=Server=YOUR_SERVER;Database=WixiCore_Staging;User Id=wixi;Password=XXX;TrustServerCertificate=True
STAGING_JWT_SECRET=staging-jwt-secret-min-32-chars
STAGING_API_URL=https://api-staging.yourdomain.com/api/v1

# ─── Production (GitHub Secret olarak da eklenir) ────────────────────────────
PROD_DB_CONNECTION=Server=YOUR_SERVER;Database=WixiCore_Production;User Id=wixi;Password=XXX;TrustServerCertificate=True;MultipleActiveResultSets=True
PROD_JWT_SECRET=prod-jwt-secret-min-32-chars-CHANGE-THIS
PROD_STRIPE_SECRET_KEY=sk_live_...
PROD_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Mail (tüm ortamlarda aynı veya farklı olabilir) ─────────────────────────
MAIL_HOST=smtp.yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=your-mail-password

# ─── Deploy (release pipeline'da kullanılır) ─────────────────────────────────
APP_VERSION=v1.0.0
