{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "SecretKey": "YOUR_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "Wixi.API",
    "Audience": "Wixi.Frontend",
    "ExpiryMinutes": 1440
  },
  "MailSettings": {
    "Server": "smtp.gmail.com",
    "Port": 587,
    "SenderName": "WIXI System",
    "SenderEmail": "system@wixi.com",
    "Username": "your-email@gmail.com",
    "Password": "your-app-password",
    "EnableSsl": true
  },
  "AppUrls": {
    "FrontendBaseUrl": "http://localhost:5183"
  },
  "AuthSecurity": {
    "OtpPepper": "",
    "FallbackOtpPepperToJwtSecret": true,
    "TwoFactorResendCooldownSeconds": 60,
    "RefreshCookieName": "wixi_rt",
    "RefreshCookieHttpOnly": true,
    "RefreshCookieSecure": true,
    "RefreshCookieSameSite": "None",
    "RefreshCookiePath": "/",
    "RefreshCookieDomain": null,
    "RefreshTokenLifetimeDays": 30
  },
  "AppCors": {
    "Origins": [
      "http://localhost:5183",
      "http://localhost:5173",
      "http://127.0.0.1:5183",
      "https://app-test.wixisoftware.com",
      "https://app.wixisoftware.com"
    ]
  },
  "AuthRateLimits": {
    "LoginPermitPerMinute": 30,
    "VerifyTwoFactorPermitPerMinute": 40,
    "ResendTwoFactorPermitPerMinute": 15,
    "RefreshPermitPerMinute": 60,
    "ForgotPasswordPermitPerMinute": 8,
    "ResetPasswordPermitPerMinute": 15,
    "RegisterPermitPerMinute": 20,
    "LogoutAllPermitPerMinute": 30
  },
  "Stripe": {
    "PublishableKey": "pk_test_YOUR_PUBLISHABLE_KEY",
    "SecretKey": "sk_test_YOUR_SECRET_KEY",
    "WebhookSecret": "whsec_YOUR_WEBHOOK_SECRET"
  }
}
